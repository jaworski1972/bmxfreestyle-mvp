# Public app URL used in generated e-mail links.
APP_URL=https://bmxfreestyle.pl

# Supabase server-side credentials. Use the service role key only in Vercel env/API runtime.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Resend e-mail delivery.
RESEND_API_KEY=replace-with-resend-api-key
MAIL_FROM=BMX Freestyle Polska <zapisy@bmxfreestyle.pl>
MAIL_REPLY_TO=kontakt@bmxfreestyle.pl
ADMIN_NOTIFICATION_EMAIL=organizator@bmxfreestyle.pl

# Admin auth for production/staging serverless API.
# Local mock login stays admin/admin in dev-server.js only.
ADMIN_LOGIN=replace-with-admin-login
ADMIN_PASSWORD=replace-with-strong-password
ADMIN_AUTH_SECRET=replace-with-long-random-session-secret

# Optional SMS delivery. Safe defaults keep automatic SMS disabled.
SMS_PROVIDER=
SMS_API_TOKEN=
SMS_FROM=
SMS_DRY_RUN=true
SEND_SMS_ON_REGISTRATION=false
SEND_SMS_ON_ACCEPTED=false
